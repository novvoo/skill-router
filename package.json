{
  "name": "skill-router",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx scripts/build-vendor.ts && tsx watch src/index.ts",
    "dev:terminal": "tsx scripts/build-vendor.ts && tsx src/index.ts --terminal",
    "dev:coordinator": "tsx scripts/build-vendor.ts && tsx src/index.ts --terminal --coordinator",
    "build": "tsc -p tsconfig.json",
    "build:frontend": "npm run build:vendor",
    "start": "node dist/index.js",
    "start:terminal": "node dist/index.js --terminal",
    "start:coordinator": "node dist/index.js --terminal --coordinator",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test:agents": "tsx scripts/test-agents.ts",
    "test:system": "node test-system.js",
    "test:tasks": "npm run build && node test-tasks.js",
    "terminal": "npm run build && npm run start:terminal",
    "smoke": "tsx scripts/smoke.ts",
    "smoke:memory-timeout": "tsx scripts/memory-timeout-smoke.ts",
    "smoke:sse": "tsx scripts/sse-smoke.ts",
    "build:vendor": "tsx scripts/build-vendor.ts"
  },
  "dependencies": {
    "@kreuzberg/node": "^4.4.6",
    "@opendataloader/pdf": "^2.0.2",
    "busboy": "^1.6.0",
    "dompurify": "^3.2.7",
    "highlight.js": "^11.11.1",
    "marked": "^15.0.7",
    "onnxruntime-node": "^1.24.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/busboy": "^1.5.4",
    "@types/node": "^22.13.4",
    "esbuild": "^0.25.2",
    "tsx": "^4.19.2",
    "typescript": "^5.8.2"
  }
}
