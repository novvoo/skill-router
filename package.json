{
  "name": "skill-router",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx scripts/build-vendor.ts && tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "smoke": "tsx scripts/smoke.ts",
    "build:vendor": "tsx scripts/build-vendor.ts"
  },
  "dependencies": {
    "@kreuzberg/wasm": "^4.4.6",
    "busboy": "^1.6.0",
    "dompurify": "^3.2.7",
    "highlight.js": "^11.11.1",
    "marked": "^15.0.7"
  },
  "devDependencies": {
    "@types/busboy": "^1.5.4",
    "@types/node": "^22.13.4",
    "esbuild": "^0.25.2",
    "tsx": "^4.19.2",
    "typescript": "^5.8.2"
  }
}
